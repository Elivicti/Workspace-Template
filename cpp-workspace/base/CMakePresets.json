{
	"version": 3,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 21,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"generator": "Ninja Multi-Config",
			"binaryDir": "${sourceDir}/build/${presetName}",
			"installDir": "${sourceDir}/build/${presetName}/install",
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": true,
				"CMAKE_CXX_STANDARD": "20",
				"CMAKE_CXX_STANDARD_REQUIRED": true,
				"CMAKE_CXX_EXTENSIONS": false
			}
		},
		{
			"name": "compiler-msvc",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_C_COMPILER": "cl.exe",
				"CMAKE_CXX_COMPILER": "cl.exe",
				"CMAKE_LINKER": "link.exe"
			}
		},
		{
			"name": "compiler-gcc",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_C_COMPILER": "gcc",
				"CMAKE_CXX_COMPILER": "g++"
			}
		},
		{
			"name": "compiler-clang",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_C_COMPILER": "clang",
				"CMAKE_CXX_COMPILER": "clang++"
			}
		},
		{
			"name": "compiler-clang-cl",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_C_COMPILER": "clang-cl",
				"CMAKE_CXX_COMPILER": "clang-cl"
			}
		},

		{
			"name": "x64-windows",
			"inherits": [ "base", "compiler-msvc" ],
			"toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
			"cacheVariables": {
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			},
			"architecture": {
				"value": "x64",
				"strategy": "external"
			}
		},
		{
			"name": "x64-linux",
			"inherits": [ "base", "compiler-clang" ],
			"cacheVariables": {
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			},
			"architecture": {
				"value": "x64",
				"strategy": "external"
			}
		}
	],
	"buildPresets": [
		{
			"name": "x64-win-debug",
			"configurePreset": "x64-windows",
			"configuration": "Debug"
		},
		{
			"name": "x64-win-release",
			"configurePreset": "x64-windows",
			"configuration": "Release"
		},
		{
			"name": "x64-win-relwithdebinfo",
			"configurePreset": "x64-windows",
			"configuration": "RelWithDebInfo"
		},


		{
			"name": "x64-linux-debug",
			"configurePreset": "x64-linux",
			"configuration": "Debug"
		},
		{
			"name": "x64-linux-release",
			"configurePreset": "x64-linux",
			"configuration": "Release"
		},
		{
			"name": "x64-linux-relwithdebinfo",
			"configurePreset": "x64-linux",
			"configuration": "RelWithDebInfo"
		}
	]
}
