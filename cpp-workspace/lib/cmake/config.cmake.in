@PACKAGE_INIT@


set_and_check(@PROJECT_NAME@_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")

include(CMakeFindDependencyMacro)

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")

set(@PROJECT_NAME@_FOUND 1)
set(@PROJECT_NAME@_VERSION @PROJECT_VERSION@)
set(@PROJECT_NAME@_ALL_COMPONENTS "@PROJECT_COMPONENTS@")


function(@SANITIZED_PROJECT_NAME@_find_component comp)
	if (@PROJECT_NAME@_${comp}_FOUND)
		return()
	endif()
	if(TARGET @PROJECT_NAME@::${comp})
		set(@PROJECT_NAME@_${comp}_FOUND 1 PARENT_SCOPE)
		check_required_components(${comp})
	else()
		set(@PROJECT_NAME@_${comp}_FOUND 0 PARENT_SCOPE)
	endif()
endfunction()


set(@PROJECT_NAME@_LIBRARIES "")
foreach(comp ${@PROJECT_NAME@_FIND_COMPONENTS})
	string(TOUPPER ${comp} comp_upper)

	if(@PROJECT_NAME@_FIND_REQUIRED_${comp_upper})
		set(required REQUIRED)
	else()
		set(required "")
	endif()

	@SANITIZED_PROJECT_NAME@_find_component(${comp})

	if(@PROJECT_NAME@_${comp}_FOUND)
		list(APPEND @PROJECT_NAME@_LIBRARIES @PROJECT_NAME@::${comp})
	endif()
endforeach()


if(NOT @PROJECT_NAME@_FIND_COMPONENTS)
	foreach(comp_ ${@PROJECT_NAME@_ALL_COMPONENTS})
		@SANITIZED_PROJECT_NAME@_find_component(${comp_})
		if(@PROJECT_NAME@_${comp_}_FOUND)
			list(APPEND @PROJECT_NAME@_LIBRARIES @PROJECT_NAME@::${comp_})
		endif()
	endforeach()
endif()

include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(@PROJECT_NAME@
	FOUND_VAR @PROJECT_NAME@_FOUND
	REQUIRED_VARS @PROJECT_NAME@_LIBRARIES
	VERSION_VAR @PROJECT_NAME@_VERSION
	HANDLE_COMPONENTS
)

